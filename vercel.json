{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/student/(.*)",
      "destination": "/student/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://quiz-management-system-f8wm.onrender.com/api/$1"
    },
    {
      "source": "/",
      "destination": "/student/index.html"
    }
  ]
}
